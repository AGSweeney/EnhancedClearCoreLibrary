int32_t ArcInterpolator::AngleToQx(double angleRad) {
    // Convert radians to Q15 format
    // Q15: 32768 = 2π radians
    // angleQx = angleRad * 32768 / (2π)
    const double scale = 32768.0 / (2.0 * M_PI);
    return (int32_t)(angleRad * scale);
